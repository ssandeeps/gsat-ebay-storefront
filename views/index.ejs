<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= pageTitle %></title>
  <meta name="description" content="<%= pageDescription %>" />
  <link rel="canonical" href="<%= siteUrl %>/" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= pageDescription %>" />
  <meta property="og:url" content="<%= siteUrl %>/" />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- ItemList structured data helps search engines understand this is a product listing page -->
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": listings.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${siteUrl}/products/${item.slug}`
    }))
  }) %>
  </script>

  <link rel="stylesheet" href="<%= basePath %>/static/style.css" />
</head>
<body>

  <header class="site-header">
    <a href="<%= basePath %>/" class="brand">G-SAT International</a>
    <p class="tagline">Industrial Automation Parts — Live eBay Inventory</p>
  </header>

  <main>
    <h1 class="page-heading">Shop Our Parts (<%= listings.length %> in stock)</h1>

    <nav class="breadcrumb"><span>eBay Listings</span> / <a href="<%= basePath %>/inventory">Live Inventory</a></nav>

    <div class="search-bar">
      <input type="text" id="listingSearch" placeholder="Search by part name or manufacturer..." autocomplete="off" />
      <span id="searchMeta" class="search-meta"></span>
    </div>

    <% if (listings.length === 0) { %>
      <p class="empty-state">No active listings found right now. Check back soon.</p>
    <% } else { %>
      <div class="listings-grid" id="listingsGrid">
        <% listings.forEach(function(item) { %>
          <div class="listing-card" data-search="<%= (item.title + ' ' + (item.currency||'')).toLowerCase().replace(/"/g,'') %>">
            <a class="listing-link" href="<%= basePath %>/products/<%= item.slug %>">
              <img
                src="<%= item.image || (basePath + '/static/placeholder.png') %>"
                alt="<%= item.title %>"
                loading="lazy"
                width="220" height="180"
              />
              <div class="card-body">
                <h2><%= item.title %></h2>
                <div class="price"><%= item.currency %> <%= item.price %></div>
                <div class="qty">
                  <% if (item.quantity - item.quantitySold > 0) { %>
                    In stock: <%= item.quantity - item.quantitySold %>
                  <% } else { %>
                    Out of stock
                  <% } %>
                </div>
              </div>
            </a>
            <div class="card-actions">
              <a class="row-btn whatsapp-btn"
                 href="https://wa.me/916360790704?text=<%= encodeURIComponent('Hi, I\'d like to enquire about ' + item.title + ' — is this in stock?') %>"
                 target="_blank" rel="noopener noreferrer">WhatsApp</a>
              <a class="row-btn enquire-btn"
                 href="mailto:sales@gsatinternational.com?subject=<%= encodeURIComponent('Enquiry: ' + item.title) %>&body=<%= encodeURIComponent('Hi, I would like to enquire about this item:\n\n' + item.title + '\n' + siteUrl + '/products/' + item.slug) %>">Enquire</a>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </main>

  <footer class="site-footer">
    <p>&copy; <%= new Date().getFullYear() %> G-SAT International. Listings sourced live from eBay.</p>
  </footer>

  <script>
    (function(){
      var input = document.getElementById('listingSearch');
      var meta = document.getElementById('searchMeta');
      var grid = document.getElementById('listingsGrid');
      if(!input || !grid) return;

      var cards = Array.prototype.slice.call(grid.querySelectorAll('.listing-card'));
      var total = cards.length;

      function updateMeta(shownCount){
        if(input.value.trim() === ''){
          meta.textContent = '';
        } else {
          meta.textContent = 'Showing ' + shownCount + ' of ' + total + ' parts';
        }
      }

      input.addEventListener('input', function(){
        var q = input.value.trim().toLowerCase();
        var shown = 0;
        cards.forEach(function(card){
          var match = q === '' || card.getAttribute('data-search').indexOf(q) !== -1;
          card.style.display = match ? '' : 'none';
          if(match) shown++;
        });
        updateMeta(shown);
      });
    })();
  </script>
</body>
</html>
