# Copy to ".env" and fill in real values. Never commit ".env" to git.

# Generate a FRESH eBay User Token — revoke any token that was ever shared/screenshotted.
EBAY_USER_TOKEN=your_token_here

EBAY_API_URL=https://api.ebay.com/ws/api.dll
EBAY_SITE_ID=0

# Your live site domain — used to build canonical URLs, sitemap, and Open Graph tags
SITE_URL=https://www.gsatinternational.com

# How often to refresh the eBay cache, in minutes
CACHE_MINUTES=15

PORT=3001
